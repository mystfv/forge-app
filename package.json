{
  "name": "forge-desktop",
  "version": "1.1.2",
  "description": "FORGE — The Discipline OS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack:win": "electron-builder --win",
    "pack:mac": "electron-builder --mac",
    "pack:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.forge.disciplineos",
    "productName": "FORGE",
    "copyright": "Copyright © 2026 FORGE",
    "asar": false,
    "publish": {
      "provider": "github",
      "owner": "mystfv",
      "repo": "forge-app",
      "releaseType": "release"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "web/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.health-fitness"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ]
    }
  }
}
